{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "asset",
    "authorization",
    "allowed_methods",
    "rate_limit_rps",
    "controlled_accounts",
    "prohibited"
  ],
  "properties": {
    "asset": {
      "type": "string"
    },
    "authorization": {
      "enum": [
        "written",
        "owned-local-lab"
      ]
    },
    "allowed_methods": {
      "type": "array"
    },
    "rate_limit_rps": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "controlled_accounts": {
      "type": "array"
    },
    "prohibited": {
      "type": "array"
    }
  },
  "additionalProperties": false
}
