{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "claim_id",
    "nodes",
    "edges"
  ],
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind"
        ]
      }
    },
    "edges": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "relation"
        ]
      }
    }
  }
}
