{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "status",
    "confidence",
    "security_invariant",
    "evidence_ids",
    "alternatives_checked",
    "impact",
    "unverified_limits"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "confirmed",
        "inconclusive",
        "discarded",
        "stopped"
      ]
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "security_invariant": {
      "type": "object",
      "required": [
        "expected",
        "observed"
      ]
    },
    "evidence_ids": {
      "type": "array",
      "minItems": 1
    },
    "alternatives_checked": {
      "type": "array"
    },
    "impact": {
      "type": "object"
    },
    "unverified_limits": {
      "type": "array"
    }
  }
}
