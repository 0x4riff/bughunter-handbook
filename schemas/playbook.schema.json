{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bug Hunting Playbook",
  "type": "object",
  "required": [
    "id",
    "version",
    "title",
    "triggers",
    "scope_requirements",
    "risk",
    "security_invariant",
    "workflow",
    "confirmation",
    "false_positive_checks",
    "stop_conditions",
    "output"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9.-]+$"
    },
    "version": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "triggers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "scope_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "object",
      "required": [
        "production_state_change",
        "max_requests_per_case"
      ]
    },
    "security_invariant": {
      "type": "string"
    },
    "workflow": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "action",
          "expect"
        ]
      }
    },
    "confirmation": {
      "type": "object",
      "required": [
        "all"
      ]
    },
    "false_positive_checks": {
      "type": "array",
      "minItems": 1
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1
    },
    "output": {
      "type": "object",
      "required": [
        "minimum_confidence",
        "finding_title"
      ]
    }
  },
  "additionalProperties": false
}
